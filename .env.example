# Copy this file to `.env` and fill in real values.
# Vite only exposes variables prefixed with VITE_ to client code, and bakes
# them in at build time — they are NOT secrets, they are baked into the JS
# bundle and visible to every visitor. Don't put real credentials here.

# ----- Backend API base URL ------------------------------------------------
# The Cozie backend that the frontend should call.
# Pass as `--build-arg VITE_API_URL=...` when building the Docker image so the
# baked value matches your environment.
#
# Examples:
#   VITE_API_URL=http://localhost:5000          (local dev)
#   VITE_API_URL=https://api.your-domain.com    (prod)
VITE_API_URL=http://localhost:5000
