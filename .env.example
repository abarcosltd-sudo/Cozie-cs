# Copy this file to `.env` and fill in real values.
# Vite only exposes variables prefixed with VITE_ to client code, and bakes
# them in at build time — they are NOT secrets, they are baked into the JS
# bundle and visible to every visitor. Don't put real credentials here.

# ----- Backend API base URL ------------------------------------------------
# The Cozie backend that the frontend should call.
# Pass as `--build-arg VITE_API_URL=...` when building the Docker image so the
# baked value matches your environment.
#
# Examples:
#   VITE_API_URL=http://localhost:5000          (local dev)
#   VITE_API_URL=https://api.your-domain.com    (prod)
VITE_API_URL=http://localhost:5000

# ----- Google Sign-In ------------------------------------------------------
# OAuth 2.0 Web client ID from Google Cloud Console
# (APIs & Services -> Credentials -> OAuth 2.0 Client IDs). Same value as
# the backend's GOOGLE_CLIENT_ID. Used by Google Identity Services (GIS)
# to mint ID tokens; the backend verifies them against the same client ID.
# Required for the "Continue with Google" / "Sign up with Google" buttons
# on /login and /signup. When unset, those buttons are hidden.
# VITE_GOOGLE_CLIENT_ID=1234567890-xxxxxxxxxxxx.apps.googleusercontent.com

# ----- Feature flags -------------------------------------------------------
# Music-merge for reels: client-side ffmpeg.wasm pipeline that bakes the
# picked song into the user's video before upload. See
# `src/lib/videoMerge.ts` and `Cozie-cs/PROGRESS.md` "Reels background
# music merge".
#
# Set to "false" to disable the merge entirely:
#   - the MusicTrimmer no longer renders
#   - submit always uploads the raw video and just attributes `songId`
# Useful as a kill switch if a mobile cohort hits widespread merge
# failures and we need to disable music-baking without a revert.
#
# Default if unset: enabled.
VITE_ENABLE_MUSIC_MERGE=true
